# CA-AIDev Shared Environment Variables
# Copy this file to .env and fill in your actual values

# =============================================================================
# INFRASTRUCTURE
# =============================================================================

# Timezone (California)
TIMEZONE=America/Los_Angeles

# =============================================================================
# n8n CONFIGURATION
# =============================================================================

# n8n Authentication
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-this-password

# n8n Host Configuration
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# =============================================================================
# DATABASE - PostgreSQL
# =============================================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ca_aidev
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=ca_aidev

# Individual Project Databases
BIZBOT_DB=bizbot
COMMENTBOT_DB=commentbot
ADABOT_DB=adabot
WISEBOT_DB=wisebot

# =============================================================================
# DATABASE - Neo4j (for Domain Crawler)
# =============================================================================

NEO4J_USER=neo4j
NEO4J_PASSWORD=change-this-password
NEO4J_URI=bolt://localhost:7687

# =============================================================================
# DATABASE - Qdrant (Vector Database)
# =============================================================================

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=ca_licensing

# =============================================================================
# AI MODEL PROVIDERS
# =============================================================================

# OpenAI (GPT-4, GPT-4 Turbo, Embeddings, Whisper)
OPENAI_API_KEY=sk-...

# Anthropic (Claude 3.5 Sonnet)
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (Gemini 1.5 Pro)
GOOGLE_AI_API_KEY=...

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# SMTP Settings (for BizBot, WiseBot)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@ca.gov
SMTP_PASSWORD=change-this-password
SMTP_FROM_EMAIL=noreply@ca.gov
SMTP_FROM_NAME=California AI Services

# Gmail OAuth (for WiseBot ingestion)
GMAIL_CLIENT_ID=...
GMAIL_CLIENT_SECRET=...

# =============================================================================
# FORM INTEGRATION
# =============================================================================

# Tally Forms
TALLY_WEBHOOK_SECRET=...

# Google Sheets API
GOOGLE_SHEETS_CLIENT_ID=...
GOOGLE_SHEETS_CLIENT_SECRET=...

# =============================================================================
# BIZBOT CONFIGURATION
# =============================================================================

# BizBot Vector Database
BIZBOT_QDRANT_COLLECTION=ca_licensing

# BizBot Email Settings
BIZBOT_FROM_EMAIL=bizbot@ca.gov
BIZBOT_REPLY_TO=support@ca.gov

# =============================================================================
# WISEBOT CONFIGURATION
# =============================================================================

# WiseBot Email Subject Filter
WISEBOT_EMAIL_SUBJECT=WiseBotMindMeld
WISEBOT_OPS_EMAIL=ops@ca.gov

# WiseBot Embedding Settings
WISEBOT_EMBEDDING_MODEL=text-embedding-3-small
WISEBOT_CHUNK_SIZE=1000
WISEBOT_CHUNK_OVERLAP=200
WISEBOT_SIMILARITY_THRESHOLD=0.85

# Supabase (if using for WiseBot instead of local PostgreSQL)
SUPABASE_URL=https://[PROJECT_ID].supabase.co
SUPABASE_SERVICE_ROLE_KEY=...

# =============================================================================
# DOMAIN CRAWLER CONFIGURATION
# =============================================================================

# Scrapy Settings
CRAWLER_USER_AGENT=Mozilla/5.0 (compatible; CA-DomainCrawler/1.0)
CRAWLER_CONCURRENT_REQUESTS=16
CRAWLER_DOWNLOAD_DELAY=1

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================

# pgAdmin (Database Management UI)
PGADMIN_EMAIL=admin@ca.gov
PGADMIN_PASSWORD=change-this-password

# Docling (for WiseBot document parsing)
DOCLING_API_URL=http://localhost:8080

# Google Cloud Vision (for enhanced OCR)
GOOGLE_CLOUD_VISION_API_KEY=...

# Deepgram (alternative speech-to-text)
DEEPGRAM_API_KEY=...

# =============================================================================
# MONITORING & LOGGING
# =============================================================================

# Log Levels (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Sentry (Optional error tracking)
SENTRY_DSN=...

# =============================================================================
# SECURITY
# =============================================================================

# JWT Secret (if implementing API authentication)
JWT_SECRET=change-this-secret-key

# API Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
